[user]
    name = Edward Nolan
☣️🍎💾🌐    email = eddiejnolan@gmail.com
🍏🔶📒    email = enolan@maystreet.com
✴️[alias]
    co = checkout
    ci = commit
    st = status
    br = branch
    cv = commit -v
    cav = commit -av
    com = checkout main
    hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
[core]
    sshCommand = ssh -i ~/.ssh/id_ed25519_git
[grep]
    lineNumber = true
[diff]
    ignoreSubmodules = dirty
[merge]
    stat = false
[init]
    defaultBranch = main
🍎[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
📒[url "ssh://gerrit.corp.maystreet.com:29418/"]
        insteadOf = https://gerrit.corp.maystreet.com/a/
