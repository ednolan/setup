# -*- mode: sh; sh-shell: bash; -*-
export EDITOR="nano"

# https://unix.stackexchange.com/a/27591
export IGNOREEOF=1

# https://www.gnu.org/software/emacs/manual/html_node/efaq/Colors-on-a-TTY.html
export COLORTERM=truecolor

export PATH="$HOME/localbuild/tmux/bin:$PATH"
export PATH="$HOME/localbuild/emacs/bin:$PATH"
export PATH="$HOME/localbuild/ripgrep/ripgrep/target/release:$PATH"
export PATH="$HOME/localbuild/fastmod/fastmod/target/release:$PATH"
export PATH="$HOME/localbuild/websocat/websocat/target/release:$PATH"
export PATH="$HOME/localbin/fzf:$PATH"
export PATH="$HOME/localbin/neuron:$PATH"
export PATH="$HOME/localbin/powershell:$PATH"
export PATH="$HOME/localbin/session-manager-plugin/usr/local/sessionmanagerplugin/bin:$PATH"
export PATH="$HOME/sync/rust/emojisplit/target/release:$PATH"
export PATH="$HOME/localbuild/mosh/prefix/bin:$PATH"

export COLOR_RESET=$(echo -en "\x1b[0m\n") \
export COLOR_CWD=$(printf '\[\x1b[38;2;0;0;255m\]')
export COLOR_GIT=$(printf '\[\x1b[38;2;0;102;255m\]')
export COLOR_SUCCESS=$(printf '\[\x1b[38;2;3;106;7m\]')
export COLOR_FAILURE=$(printf '\[\x1b[38;2;197;6;11m\]')
export SYMBOL_GIT_BRANCH='→'

source ~/sync/setup/bash-powerline/bash-powerline.sh

if [ -f ~/.bash_aliases ]; then
    source ~/.bash_aliases
fi

 if [ -f ~/.bash_functions ]; then
    source ~/.bash_functions
fi

source "$HOME/.cargo/env"

# for atuin
[[ -f $HOME/sync/setup/bash-preexec/bash-preexec.sh ]] && \
    source $HOME/sync/setup/bash-preexec/bash-preexec.sh

eval "$(atuin init bash --disable-up-arrow)"
eval "$(atuin hex init)"

export LD_PRELOAD=/usr/lib64/proxychains-ng/libproxychains4.so
export PROXYCHAINS_QUIET_MODE=1

if [[ -f ~/aws_aliases.sh ]] ; then
  source ~/aws_aliases.sh
fi

# https://unix.stackexchange.com/a/217223
if [[ ! -S /scratch/local/enolan/ssh_auth_sock ]]; then
  eval `ssh-agent`
  ln -sf "$SSH_AUTH_SOCK" /scratch/local/enolan/ssh_auth_sock
fi
export SSH_AUTH_SOCK=/scratch/local/enolan/ssh_auth_sock
ssh-add -l > /dev/null || (ssh-add && ssh-add ~/.ssh/id_ed25519_git)

if command -v gpg >/dev/null 2>&1 && command -v gpg-agent >/dev/null 2>&1 \
   && gpg --list-keys enolan@maystreet.com >/dev/null 2>&1; then
  export GPG_TTY=$(tty)

  # Resolve keygrips once, cache in a file
  _gpg_keygrip_cache=~/.gnupg/.keygrips_eddiejnolan
  if [[ ! -f "$_gpg_keygrip_cache" ]]; then
    gpg --list-keys --with-keygrip enolan@maystreet.com 2>/dev/null \
      | awk '/\[S\]/{getline; print "sign " $3} /\[E\]/{getline; print "enc " $3}' \
      > "$_gpg_keygrip_cache"
  fi

  _sign_grip=$(awk '/^sign/{print $2}' "$_gpg_keygrip_cache")
  _enc_grip=$(awk '/^enc/{print $2}' "$_gpg_keygrip_cache")

  # Check agent cache and prompt only for uncached keygrips
  _agent_check() {
    gpg-connect-agent "KEYINFO $1" /bye 2>/dev/null | grep -q "KEYINFO $1 D - - 1"
  }

  if [[ -n "$_sign_grip" ]] && ! _agent_check "$_sign_grip"; then
    echo "test" | gpg --local-user enolan@maystreet.com -as -o /dev/null 2>/dev/null
  fi

  if [[ -n "$_enc_grip" ]] && ! _agent_check "$_enc_grip"; then
    echo "test" | gpg -er enolan@maystreet.com 2>/dev/null | gpg -d -o /dev/null 2>/dev/null
  fi

  unset _sign_grip _enc_grip _gpg_keygrip_cache
fi